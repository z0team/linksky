# Public site URL used for metadata, canonical URLs and sitemap entries.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Backblaze B2 private bucket configuration.
MEDIA_STORAGE_DRIVER=b2

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linksky

# Optional PostgreSQL settings for managed providers like Supabase.
POSTGRES_SSL=require
PG_POOL_MAX=10

# Backblaze B2 S3-compatible configuration.
B2_REGION=us-west-004
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_BUCKET=linksky-media
B2_KEY_ID=
B2_APPLICATION_KEY=
